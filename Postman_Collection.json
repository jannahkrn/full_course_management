    {
      "name": "Student",
      "description": "Endpoint untuk Student: daftar course yang diikuti, detail, unenroll, dan activity log.",
      "item": [
        {
          "name": "Daftar Course Saya",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/student/courses?keyword=&category_id=&per_page=10", "host": ["{{base_url}}"], "path": ["student","courses"], "query": [{ "key": "keyword", "value": "" }, { "key": "category_id", "value": "" }, { "key": "per_page", "value": "10" }] }
          },
          "response": []
        },
        {
          "name": "Detail Course + Materi (Student)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/student/courses/{{course_id}}/detail", "host": ["{{base_url}}"], "path": ["student","courses","{{course_id}}","detail"] }
          },
          "response": []
