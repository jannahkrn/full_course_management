            "url": { "raw": "{{base_url}}/admin/courses/{{course_id}}/sessions/{{session_id}}", "host": ["{{base_url}}"], "path": ["admin","courses","{{course_id}}","sessions","{{session_id}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Pertemuan 1 — Updated\",\n  \"order\": 1\n}" }
