            "url": { "raw": "{{base_url}}/admin/courses/{{course_id}}/sessions/reorder", "host": ["{{base_url}}"], "path": ["admin","courses","{{course_id}}","sessions","reorder"] },
            "body": { "mode": "raw", "raw": "{\n  \"session_ids\": [3, 1, 2]\n}" }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Teacher",
      "description": "Endpoint untuk Teacher (dan Admin): katalog course yang diampu, sesi, dan peserta.",
